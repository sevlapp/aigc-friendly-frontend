# Vite production 模式配置示例。
# 本地实际使用时，请创建 `env/.env.production.local`。

# 与当前 Vite 默认行为保持一致：
BUILD_OUT_DIR=dist
BUILD_SOURCEMAP=false
BUILD_CHUNK_WARNING_LIMIT=1000

# GraphQL API 地址示例：
VITE_GRAPHQL_ENDPOINT=https://api.example.com/graphql
VITE_API_HEALTH_ENDPOINT=https://api.example.com/health
VITE_API_READINESS_ENDPOINT=https://api.example.com/health/readiness

# 提供给后端 INVITE_FRONTEND_URL 使用的前端邀请入口。
# 后端应配置为这个入口，不包含 inviteType/token。
# 示例：INVITE_FRONTEND_URL=https://your-app.com/invite
